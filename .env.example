# Instagram Content Generator - Environment Variables

# =========================
# Core API Server
# =========================
# HTTP port for Express server
PORT=3000

# Output directory served by /api/renders (code default: /tmp/renders)
# RENDER_DIR=/tmp/renders

# MP4 rendering concurrency (higher uses more CPU/RAM)
RENDER_CONCURRENCY=1
# Per-slide render timeout for PNG/MP4 in milliseconds
RENDER_TIMEOUT_MS=60000

# Chrome cleanup safety controls
# Every 1 hour by default
CHROME_CLEANUP_INTERVAL_MS=3600000
# Retry count after the initial cleanup attempt
CHROME_CLEANUP_RETRIES=3
# Delay between retry attempts
CHROME_CLEANUP_RETRY_DELAY_MS=1000

# =========================
# Content Generation
# =========================
# Required: Google Gemini API key
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Timeout for a single Gemini generation call in milliseconds
GEMINI_TIMEOUT_MS=60000


# Required: GNews API key
# Get one at: https://gnews.io/
GNEWS_API_KEY=your_gnews_api_key_here

# GNews API configuration
# Language code (e.g. en, de, fr)
GNEWS_LANG=en
# Country code (e.g. us, gb, de)
GNEWS_COUNTRY=us
# Max articles per request (free plan: 10)
GNEWS_MAX_ARTICLES=10
# GNews endpoint (top-headlines or search)
GNEWS_URL=https://gnews.io/api/v4/top-headlines

# Post history (duplicate detection: URL + title fingerprint)
# file — JSON at POST_HISTORY_PATH or repo post-history.json
# postgres — requires DATABASE_URL; run scripts/migrations/001_post_history.sql (or rely on auto-create in dev)
POST_HISTORY_STORE=file
# POST_HISTORY_PATH=/data/post-history.json
# Max rows kept (file trim + Postgres prune after each insert)
POST_HISTORY_MAX_ROWS=500

# News + render pipeline tuning
RENDER_FORMAT=mp4
# Composition fps (default 30, supports 60 for smoother motion)
COMPOSITION_FPS=30
# Default Remotion composition duration (seconds)
COMPOSITION_DURATION_SECONDS=24
NEWS_CATEGORY=technology
MIN_RELEVANCE_SCORE=10
# AI carousel structure bounds (supported range: 3-5)
MIN_SLIDES=3
MAX_SLIDES=5
# Anti-repetition scoring controls
REPETITION_WINDOW_DAYS=7
REPETITION_THRESHOLD=3   # Posts with same keyword before penalty applies
REPETITION_PENALTY=20    # Score penalty per over-threshold keyword match (magnitude; applied as -N)
# Optional absolute/relative path for post history persistence file
# Defaults to project-root post-history.json when unset
# POST_HISTORY_PATH=/app/post-history.json

# RSS ingestion behavior
# Set to false to bypass RSS and use GNews directly
USE_RSS_FEEDS=true
# Per-source RSS request timeout in milliseconds
RSS_FETCH_TIMEOUT_MS=10000
# Cross-source title dedup threshold (0.0-1.0)
RSS_TITLE_DEDUP_THRESHOLD=0.6
# Optional global cache TTL override in seconds (blank uses per-source defaults)
# RSS_CACHE_TTL_SECONDS=
# Global timeout budget for parallel RSS source fetches
# Preferred name: RSS_GLOBAL_FETCH_TIMEOUT_MS. RSS_GLOBAL_TIMEOUT_MS remains supported for backward compatibility.
RSS_GLOBAL_FETCH_TIMEOUT_MS=75000
RSS_GLOBAL_TIMEOUT_MS=75000

# RSS source-health guardrails
# Consecutive source failures before cooldown is applied
RSS_SOURCE_FAILURE_THRESHOLD=3
# Cooldown duration per source in seconds
RSS_SOURCE_COOLDOWN_SECONDS=3600
# TTL for source failure counters in Redis
RSS_SOURCE_FAILURE_TTL_SECONDS=604800
# Days to retain Postgres RSS telemetry rows before weekly scheduler pruning
RSS_TELEMETRY_RETENTION_DAYS=30

# =========================
# Brand / Account Profile
# =========================
BRAND_HANDLE=@breaking_news
BRAND_DISPLAY_NAME=Breaking News
BRAND_BIO=Latest tech and business news
BRAND_NICHE=technology,business,startup
BRAND_ACCENT_COLOR=#ef4444
# Allowed values: crt, noise, vignette, chromatic, halftone
BRAND_EFFECTS=vignette,chromatic,halftone

# =========================
# Scheduler Route (/api/schedule/run)
# =========================
# Optional header secret for POST /api/schedule/run (x-scheduler-secret)
SCHEDULE_RUN_SECRET=change_me

# Required for distributed scheduling
DATABASE_URL=postgresql://user:password@host:5432/dbname
REDIS_URL=redis://default:password@host:6379

# Scheduler behavior
# Use `ACCOUNT_ID` for consistency. `SCHEDULE_ACCOUNT_ID` is deprecated.
ACCOUNT_ID=default
# (deprecated) SCHEDULE_ACCOUNT_ID=default
SCHEDULE_MIN_DELAY_HOURS=4
SCHEDULE_MAX_DELAY_HOURS=5
# Timezone-aware posting window (24h format). Scheduler skips runs outside this window.
POSTING_TIMEZONE=UTC
POSTING_HOURS_START=8
POSTING_HOURS_END=21
SCHEDULE_LOCK_TTL_SECONDS=7200
SCHEDULE_RETRY_COUNT=1
SCHEDULE_RETRY_DELAY_MS=5000

# Internal scheduler loop
# Enable the server-side polling loop instead of relying on external cron
SCHEDULER_ENABLED=false
# Poll cadence in milliseconds (default: 30 minutes, minimum: 1 minute)
SCHEDULER_POLL_INTERVAL_MS=1800000
# If startup collides with an existing lock, retry this often before waiting for the normal poll interval
SCHEDULER_STARTUP_RETRY_DELAY_MS=60000
# Maximum number of short startup retries after a lock-held result
SCHEDULER_STARTUP_MAX_RETRIES=10
# =========================
# Instagram Automation
# =========================
# Uses storage.json session created by scripts/saveSession.ts
PLAYWRIGHT_HEADLESS=true
# Optional base64-encoded Playwright storage state written to storage.json at startup
INSTAGRAM_SESSION_B64=

# =========================
# Logging
# =========================
LOG_DIR=./logs
# Set any non-empty value to enable DEBUG logs
# DEBUG=1

# =========================
# Runtime / Tests (usually not set manually)
# =========================
# NODE_ENV=production
# VITEST=true

# Optional ClickUp API token for task management and scheduling (get one at https://clickup.com/api)
CLICKUP_TOKEN=pk_your_token_here