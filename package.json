{
    "name": "instagram-content-generator-remotion",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "tsx server.ts",
        "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json --resolve-full-paths",
        "start": "tsx server.ts",
        "start:prod": "node --experimental-specifier-resolution=node dist/server.js",
        "preview": "npx remotion studio src/remotion/index.tsx",
        "pipeline": "npm exec tsx -- src/pipelineRun.ts",
        "verify": "npm exec tsx -- verify-option-b.ts",
        "test": "vitest",
        "test:integration": "vitest run __tests__/integration",
        "clickup:audit": "tsx scripts/clickup-audit.ts"
    },
    "dependencies": {
        "@google/generative-ai": "^0.24.1",
        "@remotion/bundler": "^4.0.0",
        "@remotion/cli": "^4.0.0",
        "@remotion/renderer": "^4.0.0",
        "dotenv": "^17.3.1",
        "express": "^4.18.2",
        "he": "^1.2.0",
        "lucide-react": "^0.309.0",
        "pg": "^8.16.3",
        "playwright": "^1.59.1",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "redis": "^5.8.2",
        "remotion": "^4.0.0",
        "rss-parser": "^3.13.0",
        "sanitize-html": "^2.17.2",
        "tailwindcss": "^4.0.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/he": "^1.2.3",
        "@types/pg": "^8.15.6",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "@types/sanitize-html": "^2.16.1",
        "@types/supertest": "^7.2.0",
        "supertest": "^7.2.2",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.7.0",
        "typescript": "^5.3.0",
        "vitest": "^4.0.18"
    }
}
